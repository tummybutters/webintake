# Base app URL used for Stripe success/cancel redirects
BASE_URL=https://your-project.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_CHECKOUT_MODE=payment
# Optional if STRIPE_CHECKOUT_MODE=subscription
STRIPE_TRIAL_PERIOD_DAYS=90

# Google service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account-name@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Sheets destination
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_SHEET_NAME=Submissions

# Google Drive folder for uploaded logos
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
