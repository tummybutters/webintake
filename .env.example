# Optional override for Stripe success/cancel redirects.
# In Vercel production, the API now falls back to the incoming request origin.
BASE_URL=https://your-project.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_CHECKOUT_MODE=payment
# Optional if STRIPE_CHECKOUT_MODE=subscription
STRIPE_TRIAL_PERIOD_DAYS=90

# Google service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account-name@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Sheets destination
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_SHEET_NAME=Submissions

# Vercel Blob token for uploaded logos
# In production, a Blob store connected to the same Vercel project usually works after redeploy.
# For local development, pull env vars with `vercel env pull` or set the token manually.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
